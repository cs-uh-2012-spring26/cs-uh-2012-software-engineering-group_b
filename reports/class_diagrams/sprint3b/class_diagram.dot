digraph "classes_FitnessApp" {
    rankdir=TB
    charset="utf-8"
    node [shape="record", style="solid", color="black", fontcolor="black", fontname="Helvetica"];
    edge [fontname="Helvetica", fontsize="10", labeldistance="2.5"];

    // --------------------------------------------------------
    // API LAYER (Controllers)
    // --------------------------------------------------------
    subgraph cluster_api {
        label="API Layer";
        style=dashed;
        
        "app.apis.auth.Register" [label=<{Register|<br ALIGN="LEFT"/>|post()<br ALIGN="LEFT"/>}>];
        "app.apis.auth.Login" [label=<{Login|<br ALIGN="LEFT"/>|post()<br ALIGN="LEFT"/>}>];
        
        "app.apis.fitness_class.ClassListResource" [label=<{ClassListResource|<br ALIGN="LEFT"/>|get()<br ALIGN="LEFT"/>post()<br ALIGN="LEFT"/>}>];
        "app.apis.fitness_class.ClassReminderResource" [label=<{ClassReminderResource|<br ALIGN="LEFT"/>|post(class_id: str)<br ALIGN="LEFT"/>}>];
        
        "app.apis.booking.BookingResource" [label=<{BookingResource|<br ALIGN="LEFT"/>|post()<br ALIGN="LEFT"/>}>];
        "app.apis.booking.BookingListByClassResource" [label=<{BookingListByClassResource|<br ALIGN="LEFT"/>|get(class_id: str)<br ALIGN="LEFT"/>}>];
    }

    // --------------------------------------------------------
    // SERVICE LAYER (Business Logic)
    // --------------------------------------------------------
    subgraph cluster_service {
        label="Service Layer";
        style=dashed;
        
        "app.services.auth_service.AuthService" [label=<{AuthService|<br ALIGN="LEFT"/>|register_user(data, role)<br ALIGN="LEFT"/>login_user(data)<br ALIGN="LEFT"/>}>];
        
        "app.services.token_service.TokenService" [label=<{TokenService|<br ALIGN="LEFT"/>|_VALID_TOKENS: dict<br ALIGN="LEFT"/>|resolve_role(token)<br ALIGN="LEFT"/>is_valid(token)<br ALIGN="LEFT"/>}>];
        
        "app.services.booking_service.BookingService" [label=<{BookingService|<br ALIGN="LEFT"/>|book_class(user_email, class_id)<br ALIGN="LEFT"/>}>];
        
        "app.services.fitness_class_service.FitnessClassService" [label=<{FitnessClassService|<br ALIGN="LEFT"/>|create_class(payload)<br ALIGN="LEFT"/>create_recurring_classes(payload) &lt;&lt;Feat 6&gt;&gt;<br ALIGN="LEFT"/>send_reminders(class_id, sender_email)<br ALIGN="LEFT"/>}>];
        
        "app.services.email_reminders" [label=<{email_reminders (Module)|<br ALIGN="LEFT"/>|send_class_reminders(..., sender_email) &lt;&lt;Feat 7&gt;&gt;<br ALIGN="LEFT"/>_build_reminder_message()<br ALIGN="LEFT"/>_sendgrid_api_key()<br ALIGN="LEFT"/>_sendgrid_send_email()<br ALIGN="LEFT"/>_resolve_sender_email()<br ALIGN="LEFT"/>}>];
    }

    // --------------------------------------------------------
    // DOMAIN & DATABASE LAYER (Inheritance & DTOs)
    // --------------------------------------------------------
    subgraph cluster_db {
        label="Database & Domain Layer";
        style=dashed;
        
        // --- NEW INHERITANCE HIERARCHY ---
        "app.db.users.User" [label=<{User (Abstract)|<br ALIGN="LEFT"/>USER_ID: str<br ALIGN="LEFT"/>NAME: str<br ALIGN="LEFT"/>EMAIL: str<br ALIGN="LEFT"/>PHONE: str<br ALIGN="LEFT"/>|}>];
        "app.db.users.Member" [label=<{Member|<br ALIGN="LEFT"/>|book_class()<br ALIGN="LEFT"/>}>];
        "app.db.users.Trainer" [label=<{Trainer|<br ALIGN="LEFT"/>|create_class()<br ALIGN="LEFT"/>send_reminders()<br ALIGN="LEFT"/>}>];
        "app.db.users.Admin" [label=<{Admin|<br ALIGN="LEFT"/>|manage_system()<br ALIGN="LEFT"/>}>];
        
        "app.db.users.users_module" [label=<{users (Module)|<br ALIGN="LEFT"/>|get_user_by_email(email)<br ALIGN="LEFT"/>get_user_by_phone(phone)<br ALIGN="LEFT"/>create_user(User)<br ALIGN="LEFT"/>}>];
        
        "app.db.fitness_classes" [label=<{fitness_classes (Module)|<br ALIGN="LEFT"/>CLASS_ID: str<br ALIGN="LEFT"/>CAPACITY: int<br ALIGN="LEFT"/>AVAILABLE_SPOTS: int<br ALIGN="LEFT"/>RECURRENCE_PATTERN: str &lt;&lt;Feat 6&gt;&gt;<br ALIGN="LEFT"/>|get_class_by_class_id(class_id)<br ALIGN="LEFT"/>decrement_available_spot(class_id)<br ALIGN="LEFT"/>create_fitness_class(fitness_class)<br ALIGN="LEFT"/>}>];
        
        "app.db.bookings" [label=<{bookings (Module)|<br ALIGN="LEFT"/>BookingUser (DTO)<br ALIGN="LEFT"/>BOOKING_ID: str<br ALIGN="LEFT"/>CLASS_ID: str<br ALIGN="LEFT"/>USER_ID: str<br ALIGN="LEFT"/>|build_booking_document(class_id, booking_user)<br ALIGN="LEFT"/>create_booking(booking)<br ALIGN="LEFT"/>}>];
    }

    // EXTERNAL INTEGRATION
    "External.SendGridAPI" [label=<{SendGrid API|<br ALIGN="LEFT"/>|send(message)<br ALIGN="LEFT"/>}>];

    // ========================================================
    // RELATIONSHIPS & MULTIPLICITIES
    // ========================================================
    
    // --- UML INHERITANCE (Addresses TA Feedback) ---
    "app.db.users.Member" -> "app.db.users.User" [arrowhead="empty", label=" inherits"];
    "app.db.users.Trainer" -> "app.db.users.User" [arrowhead="empty", label=" inherits"];
    "app.db.users.Admin" -> "app.db.users.User" [arrowhead="empty", label=" inherits"];

    // DATA ASSOCIATIONS
    "app.db.users.User" -> "app.db.bookings" [arrowhead="none", taillabel="1", headlabel="0..n", label=" has"];
    "app.db.fitness_classes" -> "app.db.bookings" [arrowhead="none", taillabel="1", headlabel="0..n", label=" has"];

    // API to SERVICE DELEGATION
    "app.apis.auth.Register" -> "app.services.auth_service.AuthService" [style="dashed", arrowhead="vee"];
    "app.apis.auth.Login" -> "app.services.auth_service.AuthService" [style="dashed", arrowhead="vee"];
    "app.apis.fitness_class.ClassListResource" -> "app.services.fitness_class_service.FitnessClassService" [style="dashed", arrowhead="vee"];
    "app.apis.fitness_class.ClassReminderResource" -> "app.services.fitness_class_service.FitnessClassService" [style="dashed", arrowhead="vee"];
    "app.apis.booking.BookingResource" -> "app.services.booking_service.BookingService" [style="dashed", arrowhead="vee"];
    
    // SERVICE to DB DELEGATION
    "app.services.auth_service.AuthService" -> "app.db.users.users_module" [style="dashed", arrowhead="vee"];
    "app.services.booking_service.BookingService" -> "app.db.fitness_classes" [style="dashed", arrowhead="vee"];
    "app.services.booking_service.BookingService" -> "app.db.bookings" [style="dashed", arrowhead="vee"];
    "app.services.fitness_class_service.FitnessClassService" -> "app.db.fitness_classes" [style="dashed", arrowhead="vee"];
    "app.services.fitness_class_service.FitnessClassService" -> "app.services.email_reminders" [style="dashed", arrowhead="vee"];
    
    // EXTERNAL CALLS
    "app.services.email_reminders" -> "External.SendGridAPI" [style="dashed", arrowhead="vee", label=" HTTP POST"];
}